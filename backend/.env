PORT=5001
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=5h
SESSION_TIMEOUT_HOURS=5

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin credentials (seeded on first run)
ADMIN_EMAIL=admin@freelancehub.com
ADMIN_PASSWORD=Admin@123456

# ─── Notifications (Car Hive) ───
# SMTP email (leave SMTP_HOST blank to log emails to console instead of sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Car Hive <no-reply@carhive.com>"
# Where New File Request notifications are e-mailed (defaults to ADMIN_EMAIL)
COMPANY_EMAIL=

# SMS gateway (generic HTTP/JSON; leave SMS_API_URL blank to log to console)
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER_ID=CARHIVE

# WhatsApp Cloud API (leave blank to log to console)
WHATSAPP_API_URL=
WHATSAPP_TOKEN=

NODE_ENV=development
CLIENT_URL=http://localhost:3000
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=anantha
DB_NAME=freehub
